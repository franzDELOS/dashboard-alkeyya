// Alkeyya AI — Customer Dashboard
// Prisma 7 (Rust-free): the `prisma-client` generator emits TypeScript into
// our source tree, and connectivity goes through a driver adapter (pg).
//
// Phase 0 intentionally ships ZERO domain models. Connectivity is proven with
// a raw `SELECT 1` in the API readiness probe. Auth/billing models land in
// Phase 1 alongside the first migration.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Connection URL lives in prisma.config.ts (Prisma 7 no longer allows `url`
  // here); the runtime client connects via the pg driver adapter.
}

// ---- Phase 1: Authentication ------------------------------------------------
// User accounts plus the short-lived token tables that back email verification,
// password reset, and rotating refresh-token sessions. We never store raw
// tokens — only their SHA-256 hashes — so a database leak can't be replayed.

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  firstName       String?
  lastName        String?
  companyName     String?
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // ---- Phase 2: Billing ----------------------------------------------------
  // The pilot gate: a fresh registration is NOT allowed to reach Checkout until
  // an admin manually flips isPilotApproved (a prospect runs a manual two-week
  // pilot outside this dashboard first). role distinguishes the founder/admin
  // (who can approve pilots) from customers.
  stripeCustomerId String? @unique
  // Polar (migration): the customer's id in Polar, created lazily at first
  // checkout in Phase 2. Mirrors stripeCustomerId.
  polarCustomerId  String? @unique
  isPilotApproved  Boolean @default(false)
  role             String  @default("customer") // "customer" | "admin"

  // ---- Phase 4: Admin ------------------------------------------------------
  // null = active, set = suspended. A suspended user can still authenticate at
  // /login but is blocked from every authenticated route (/me returns 403).
  suspendedAt DateTime?

  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]
  refreshTokens      RefreshToken[]
  subscription       Subscription?

  // ---- Phase 3: Support requests -------------------------------------------
  requests Request[]

  // ---- Phase 4: Admin audit trail ------------------------------------------
  // Back-reference for AuditLog.actor (the admin who performed an action). Only
  // one relation exists between User and AuditLog, so no @relation name needed.
  auditLogs AuditLog[]

  // ---- Phase 4 (Polar migration): usage metering ---------------------------
  // One UsageRecord per month tracks the calls an admin has recorded for this
  // user, the basis for overage projection against the plan's includedCalls.
  usageRecords UsageRecord[]
}

// ---- Phase 4: Admin audit trail ---------------------------------------------
// Every privileged admin action (pilot approval, request status change, user
// suspension/unsuspension) is recorded here: who did it, what they did, and
// which resource was affected. Append-only; never updated or deleted.
model AuditLog {
  id           String   @id @default(cuid())
  actorId      String // the admin who performed the action
  actor        User     @relation(fields: [actorId], references: [id])
  action       String // "pilot_approved" | "request_status_changed" | "user_suspended" | "user_unsuspended"
  resourceType String // "user" | "request" | "subscription"
  resourceId   String // the id of the affected row
  metadata     Json? // extra context, e.g. { from: "open", to: "in_progress" }
  createdAt    DateTime @default(now())

  @@index([actorId])
  @@index([resourceType, resourceId])
}

model EmailVerification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ---- Phase 2: Billing -------------------------------------------------------
// Stripe-backed subscriptions. We mirror just enough of Stripe's state into our
// own tables to gate dashboard access without a round-trip to Stripe on every
// request. Stripe remains the source of truth; webhooks keep these rows in sync.

model Plan {
  id   String @id @default(cuid())
  name String @unique // "Starter" | "Growth" | "Premium"

  // Stripe IDs are now OPTIONAL so a Polar-only plan doesn't require them. The
  // @unique constraints remain (Postgres permits multiple NULLs under a unique
  // index, so unset Polar/Stripe plans don't collide).
  stripeProductId String? @unique
  stripePriceId   String? @unique

  // ---- Polar (migration) ---------------------------------------------------
  // The Polar product backing this plan, plus the metering config for usage
  // billing. includedCalls = the monthly call allowance (null = unlimited);
  // overageUnitCents = per-call price beyond the allowance in cents (null =
  // no overage). polarMeterId links to the Polar meter for usage reporting.
  polarProductId   String? @unique
  includedCalls    Int? // null = unlimited
  overageUnitCents Int? // cents per overage call; null = no overage
  polarMeterId     String?

  monthlyPriceUsd Int // stored in cents to avoid float issues
  features        String[]
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  subscriptions Subscription[]
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique // one active subscription per user in this phase
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId               String
  plan                 Plan      @relation(fields: [planId], references: [id])
  // Stripe sub id is now OPTIONAL: a Polar-only subscription row has no Stripe
  // subscription. The @unique constraint stays (Postgres permits multiple NULLs).
  stripeSubscriptionId String?   @unique
  // Polar (migration): the subscription id in Polar. provider records which
  // billing system owns this row so the app can route correctly during and
  // after the cutover. Defaults to "stripe" for all existing rows.
  polarSubscriptionId  String?   @unique
  provider             String    @default("stripe") // "stripe" | "polar"
  status               String // mirrors provider: "trialing" | "active" | "past_due" | "suspended" | "canceled"
  currentPeriodEnd     DateTime?
  trialEndsAt          DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  invoices Invoice[]
}

model Invoice {
  id               String       @id @default(cuid())
  subscriptionId   String
  subscription     Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  stripeInvoiceId  String?      @unique
  // Polar (migration): Polar issues Orders rather than Stripe invoices. Mirrors
  // stripeInvoiceId; one of the two identifies a row depending on provider.
  polarOrderId     String?      @unique
  amountDueCents   Int
  amountPaidCents  Int
  status           String // mirrors Stripe: "paid" | "open" | "uncollectible" | "void"
  hostedInvoiceUrl String?
  createdAt        DateTime     @default(now())

  @@index([subscriptionId])
}

// Webhook idempotency ledger: every Stripe event.id is recorded here BEFORE we
// process it, so a redelivery (Stripe retries on non-2xx / timeout) is skipped.
model StripeWebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  type          String
  processedAt   DateTime @default(now())
}

// Polar (migration): the same idempotency ledger as StripeWebhookEvent, for
// Polar webhook deliveries. Every Polar event id is recorded before processing
// so a redelivery is skipped. Used from Phase 2 onward.
model PolarWebhookEvent {
  id           String   @id @default(cuid())
  polarEventId String   @unique
  type         String
  processedAt  DateTime @default(now())
}

// Polar (migration): monthly usage tally per user, the basis for overage
// billing. An admin records the call count for a period (YYYY-MM); the unique
// [userId, period] index makes resubmission an idempotent correction (upsert).
// The local row is the source of truth; Polar event ingestion is best-effort.
model UsageRecord {
  id         String   @id @default(cuid())
  userId     String
  period     String // "YYYY-MM" — one record per user per month
  calls      Int // total calls submitted for this period
  ingestedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period]) // idempotency: one submission per user per period
}

// Single typed settings row for billing-wide config (admin-editable later).
// Phase 1 introduces only trialDays (the Checkout trial length, currently a
// hardcoded 14 in the Stripe flow). One row is expected; seeded/upserted later.
model BillingConfig {
  id        String   @id @default(cuid())
  trialDays Int      @default(14)
  updatedAt DateTime @updatedAt
}

// ---- Phase 3: Support requests ----------------------------------------------
// Customer-submitted requests (support / feature / billing questions). Saved
// here, emailed to the founder's inbox, and forwarded to n8n (best-effort) for
// any downstream automation. status is updated out-of-band by the team.

model Request {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  company   String?
  email     String
  subject   String
  priority  String // "low" | "normal" | "high" | "urgent"
  message   String
  status    String   @default("open") // "open" | "in_progress" | "resolved" | "closed"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  replacedBy String?
  userAgent  String?
  ipAddress  String?
  createdAt  DateTime  @default(now())

  @@index([userId])
}
