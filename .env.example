# Alkeyya Customer Dashboard — environment template.
# Copy to .env and fill in real values. Every variable validated by
# apps/api/src/config/env.ts is documented below, grouped by the phase that
# introduced it. The API refuses to boot if a required one is missing/malformed.
# (Phase 5 added no new variables — this file is the single source of truth for
# standing the project up from scratch.)

# ---- Database (used by docker-compose + Prisma) ----------------------------
POSTGRES_USER=alkeyya                              # Postgres role name
POSTGRES_PASSWORD=change_me_to_a_long_random_secret # Postgres password (make it long)
POSTGRES_DB=alkeyya_dashboard                      # Database name

# Local (non-Docker) dev: point Prisma/API at the dockerized Postgres on 5433.
# In Docker, the api service builds this URL from the POSTGRES_* vars above.
DATABASE_URL=postgresql://alkeyya:change_me_to_a_long_random_secret@localhost:5433/alkeyya_dashboard?schema=public

# ---- API -------------------------------------------------------------------
PORT=3020                                 # API listen port
NODE_ENV=development                       # development | test | production
CORS_ORIGIN=http://localhost:3001          # Comma-separated allowed browser origin(s)

# ---- Web (local dev only; Nginx handles /api in production) -----------------
API_PROXY_TARGET=http://localhost:3020     # Where the Next.js /api rewrite forwards

# ---- Auth (Phase 1) --------------------------------------------------------
# Two DISTINCT secrets, each at least 32 chars. Generate each with:
#   openssl rand -hex 32
JWT_ACCESS_SECRET=change_me_to_a_long_random_secret_min_32_chars       # Signs short-lived access tokens
JWT_REFRESH_SECRET=change_me_to_a_different_long_random_secret_min_32  # Signs refresh tokens (must differ)

# Public URL of the web app — used to build verification/reset links in emails.
APP_URL=http://localhost:3001

# ---- Brevo transactional email (Phase 1) -----------------------------------
BREVO_API_KEY=your_brevo_api_key           # Brevo (Sendinblue) transactional API key
BREVO_SENDER_EMAIL=hello@alkeyya.com       # Verified sender address for outgoing mail
BREVO_SENDER_NAME=Alkeyya                  # Display name on outgoing mail

# ---- Stripe billing (Phase 2) ----------------------------------------------
# API keys from https://dashboard.stripe.com/test/apikeys (use TEST keys in dev).
STRIPE_SECRET_KEY=sk_test_your_secret_key             # Server-side Stripe secret key (sk_…)
# From `stripe listen` output, or the webhook endpoint's signing secret.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret # Verifies webhook signatures (whsec_…)

# Product + Price IDs for the three plans (create them in the Stripe dashboard,
# one recurring monthly USD price each). Consumed by the Prisma seed script.
STRIPE_STARTER_PRODUCT_ID=prod_xxx         # Starter plan product
STRIPE_STARTER_PRICE_ID=price_xxx          # Starter plan recurring price
STRIPE_PREMIUM_PRODUCT_ID=prod_xxx         # Premium plan product
STRIPE_PREMIUM_PRICE_ID=price_xxx          # Premium plan recurring price
STRIPE_GROWTH_PRODUCT_ID=prod_xxx          # Growth plan product
STRIPE_GROWTH_PRICE_ID=price_xxx           # Growth plan recurring price

# Stripe.js publishable key, exposed to the browser (NEXT_PUBLIC_*). Safe to be
# public; must pair with the secret key's mode (test pk_test_… with sk_test_…).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# ---- Request form → n8n (Phase 3) ------------------------------------------
# Where customer requests are POSTed for downstream automation. Required for the
# API to boot. Best-effort at request time: a failed/unreachable webhook is
# logged and never errors the customer's submission.
N8N_WEBHOOK_URL=https://automations.alkeyya.com/webhook/dashboard-request
# Sent as the `X-Webhook-Secret` header; must match the value in the n8n webhook
# node's Header Auth credential. Generate with: openssl rand -hex 32
N8N_WEBHOOK_SECRET=replace_with_a_long_random_string
