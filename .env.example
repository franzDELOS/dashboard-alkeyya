# ---- Database (used by docker-compose + Prisma) ----------------------------
POSTGRES_USER=alkeyya
POSTGRES_PASSWORD=change_me_to_a_long_random_secret
POSTGRES_DB=alkeyya_dashboard

# Local (non-Docker) dev: point Prisma/API at the dockerized Postgres on 5433.
# In Docker, the api service builds this URL from the POSTGRES_* vars above.
DATABASE_URL=postgresql://alkeyya:change_me_to_a_long_random_secret@localhost:5433/alkeyya_dashboard?schema=public

# ---- API -------------------------------------------------------------------
PORT=3020
NODE_ENV=development
CORS_ORIGIN=http://localhost:3001

# ---- Web (local dev only; Nginx handles /api in production) -----------------
API_PROXY_TARGET=http://localhost:3020

# ---- Auth (Phase 1) --------------------------------------------------------
# Two DISTINCT secrets, each at least 32 chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change_me_to_a_long_random_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_to_a_different_long_random_secret_min_32

# Public URL of the web app — used to build verification/reset links in emails.
APP_URL=http://localhost:3001

# ---- Brevo transactional email (Phase 1) -----------------------------------
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=hello@alkeyya.com
BREVO_SENDER_NAME=Alkeyya
