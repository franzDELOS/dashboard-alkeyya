# ---- Database (used by docker-compose + Prisma) ----------------------------
POSTGRES_USER=alkeyya
POSTGRES_PASSWORD=change_me_to_a_long_random_secret
POSTGRES_DB=alkeyya_dashboard

# Local (non-Docker) dev: point Prisma/API at the dockerized Postgres on 5433.
# In Docker, the api service builds this URL from the POSTGRES_* vars above.
DATABASE_URL=postgresql://alkeyya:change_me_to_a_long_random_secret@localhost:5433/alkeyya_dashboard?schema=public

# ---- API -------------------------------------------------------------------
PORT=3020
NODE_ENV=development
CORS_ORIGIN=http://localhost:3001

# ---- Web (local dev only; Nginx handles /api in production) -----------------
API_PROXY_TARGET=http://localhost:3020
