{
  "name": "alkeyya-dashboard",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "setup": "pnpm install && pnpm db:generate && pnpm -F @alkeyya/db build",
    "db:generate": "pnpm -F @alkeyya/db generate",
    "db:migrate": "pnpm -F @alkeyya/db migrate",
    "db:deploy": "pnpm -F @alkeyya/db migrate:deploy",
    "db:seed": "pnpm -F @alkeyya/db seed",
    "db:studio": "pnpm -F @alkeyya/db studio",
    "dev": "pnpm -r --parallel --filter \"./apps/*\" dev",
    "build": "pnpm -F @alkeyya/db build && pnpm -F @alkeyya/api build && pnpm -F @alkeyya/web build",
    "start:api": "pnpm -F @alkeyya/api start",
    "start:web": "pnpm -F @alkeyya/web start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  }
}
